/-!
# Universe levels

Per `fx_design.md` §31.4.  A level is a first-order term in the
algebra generated by `zero`, `succ`, binary `max`, and level
variables (for universe polymorphism, `U-poly`).

The kernel axioms realized by this file (from Appendix H.1):

  * `U-wf`     — every level expression is well-formed.  Realized
                 structurally: the `Level` inductive admits no
                 malformed construction.
  * `U-level`  — the primitives `level.zero`, `level.succ`,
                 `level.max` exist and satisfy the usual ordering
                 axioms.  In the Lean encoding they are
                 constructors of the `Level` inductive type;
                 their ordering axioms are the theorems
                 `Level.LessEq.refl`, `Level.LessEq.trans`,
                 `Level.LessEq.zero_le_closed`, `Level.LessEq.le_succ`,
                 `Level.LessEq.succ_mono`, `Level.LessEq.succ_le_succ`
                 (alias), `Level.LessEq.le_max_left`,
                 `Level.LessEq.le_max_right`, `Level.LessEq.max_comm`
                 proved below.  No `axiom` declarations.
  * `U-hier`   — `zero : succ zero : succ (succ zero) : …` is an
                 infinite hierarchy.  Realized by `eval?`
                 producing distinct `Nat` values with `Nat`
                 unbounded.
  * `U-cumul`  — the cumulativity preorder.  Realized semantically
                 via `LessEq`; the type-level consequence (a term at
                 `Type u` inhabits `Type (succ u)`) lives in
                 `FX/Kernel/Typing.lean` as a constructor of the
                 `HasType` relation, not as an `axiom` here.
  * `U-poly`   — level polymorphism.  Realized via the `var`
                 constructor.  Phase 1 rejects any closed term
                 containing `var`; Phase 2 will wire level
                 abstractions through `Typing`.

This file contains no `axiom` declarations.

## Phase status

Phase 1 uses only *closed* levels — no level variables appear in
kernel terms.  `Level.var` is part of the type from day zero so
the API need not churn when universe polymorphism lands in
Phase 2.  Until then, any kernel term containing a `Level.var` is
rejected by the checker.
-/

namespace FX.Kernel

/--
Universe levels in FX.  *Realizes `U-wf` (Appendix H.1): the
inductive admits only well-formed level expressions.*

The four constructors match `fx_design.md` §31.4 exactly:

  * `zero`     — the base universe level (`U-level`).
  * `succ u`   — one level above `u` (`U-level`, `U-hier`).
  * `max u v`  — the least upper bound of `u` and `v`
                 (`U-level`).
  * `var k`    — level variable with de Bruijn-style index `k`,
                 bound by a universe-polymorphic binder
                 (`U-poly`).

Level *values* are closed (no `var`); level *expressions* may
contain variables when appearing under `U-poly`.
-/
inductive Level : Type where
  | zero : Level
  | succ : Level → Level
  | max  : Level → Level → Level
  | var  : Nat → Level
  deriving DecidableEq, Repr, Inhabited

namespace Level

/--
Evaluate a *closed* level to its concrete natural-number value.
Returns `none` if the level contains any variable.  The kernel's
`U-cumul` check reduces to `Nat.le` on the values returned here.

Total on closed levels: a level with no `var` constructor
always evaluates to `some n` — see `eval?_closed_isSome`.
-/
def eval? : Level → Option Nat
  | zero    => some 0
  | succ predecessorLevel  => (eval? predecessorLevel).map (· + 1)
  | max leftLevel rightLevel =>
    match eval? leftLevel, eval? rightLevel with
    | some leftValue, some rightValue => some (Nat.max leftValue rightValue)
    | _,      _      => none
  | var _   => none

/-- `true` iff the level has no `var` constructor anywhere.
    Closed levels evaluate to a concrete `Nat` and participate in
    the full cumulativity preorder. -/
def closed : Level → Bool
  | zero    => true
  | succ predecessorLevel  => closed predecessorLevel
  | max leftLevel rightLevel => closed leftLevel && closed rightLevel
  | var _   => false

/-- `true` iff every `var n` occurring in the level has index
    `n < levelCount`.  Used by `inferType` to reject `Term.type
    level` when `level` references a level variable that has
    not been bound by an enclosing `forallLevel` scope (A10,
    §31.4 U-poly).  Generalizes `closed`: `closed level =
    varsInScope 0 level`. -/
def varsInScope (levelCount : Nat) : Level → Bool
  | zero          => true
  | succ inner    => varsInScope levelCount inner
  | max left right => varsInScope levelCount left && varsInScope levelCount right
  | var index     => decide (index < levelCount)

/-- A closed level evaluates: `(eval? u).isSome` for every `u`
    with `closed u = true`.  Phase 1's kernel uses this as the
    discharge for closedness hypotheses on the `max`-cumulativity
    lemmas below. -/
theorem eval?_closed_isSome :
    ∀ level : Level, closed level = true → (eval? level).isSome = true
  | zero,    _ => rfl
  | succ predecessorLevel,  hClosed => by
    have inductionHyp := eval?_closed_isSome predecessorLevel hClosed
    cases hEvalPred : eval? predecessorLevel with
    | none   => simp [hEvalPred] at inductionHyp
    | some _ => simp [eval?, hEvalPred, Option.map, Option.isSome]
  | max leftLevel rightLevel, hClosed => by
    simp only [closed, Bool.and_eq_true] at hClosed
    obtain ⟨hClosedLeft, hClosedRight⟩ := hClosed
    have isSomeLeft := eval?_closed_isSome leftLevel hClosedLeft
    have isSomeRight := eval?_closed_isSome rightLevel hClosedRight
    cases hEvalLeft : eval? leftLevel with
    | none   => simp [hEvalLeft] at isSomeLeft
    | some _ =>
      cases hEvalRight : eval? rightLevel with
      | none   => simp [hEvalRight] at isSomeRight
      | some _ => simp [eval?, hEvalLeft, hEvalRight, Option.isSome]
  | var _,   hClosed => by simp [closed] at hClosed

/--
The cumulativity preorder on levels, phrased semantically:
`u ≤ v` iff every evaluation of `u` is bounded above by some
evaluation of `v`.  For closed levels this reduces to `Nat.le` on
the evaluated values; for levels containing free variables it
holds vacuously, since `eval?` returns `none` and the antecedent
of the universal is unsatisfiable.

*Realizes `U-cumul` (Appendix H.1) at the semantic level.*  The
type-level consequence (a term at `Type u` inhabits
`Type (succ u)`) is a constructor of `HasType` in
`FX/Kernel/Typing.lean`, not an axiom.

**Phase note:** the vacuous-on-open-levels behavior makes
`LessEq (var 0) (var 1)` provable, which is semantically
questionable.  Phase 1 sidesteps this by rejecting any term
whose level contains a `var`; the vacuous case therefore cannot
appear in a well-formed kernel judgment.  Phase 2 will refine
`LessEq` to a richer relation over level-expression contexts.
-/
def LessEq (leftLevel rightLevel : Level) : Prop :=
  ∀ leftValue, eval? leftLevel = some leftValue →
    ∃ rightValue, eval? rightLevel = some rightValue ∧ leftValue ≤ rightValue

/-- `LE` instance wired to `LessEq` so the `u ≤ v` notation resolves. -/
instance : LE Level := ⟨LessEq⟩

/-- Reflexivity of cumulativity: every level is `≤` itself. -/
theorem LessEq.refl (level : Level) : level ≤ level :=
  fun value hEval => ⟨value, hEval, Nat.le_refl value⟩

/--
Transitivity of cumulativity.  With `LessEq.refl` this establishes
`LessEq` as a preorder on levels.  Antisymmetry does *not* hold at
the term representation (`max zero zero` and `zero` evaluate
equally but are syntactically distinct), so `LessEq` is not a partial
order on terms.
-/
theorem LessEq.trans {leftLevel rightLevel thirdLevel : Level}
    (leftLeRight : leftLevel ≤ rightLevel) (rightLeThird : rightLevel ≤ thirdLevel) :
    leftLevel ≤ thirdLevel :=
  fun leftValue hEvalLeft =>
    let ⟨rightValue, hEvalRight, leftLeRightVal⟩ := leftLeRight leftValue hEvalLeft
    let ⟨thirdValue, hEvalThird, rightLeThirdVal⟩ := rightLeThird rightValue hEvalRight
    ⟨thirdValue, hEvalThird, Nat.le_trans leftLeRightVal rightLeThirdVal⟩

/--
Decidable boolean counterpart of `LessEq`.  Returns `true` when both
levels close to concrete naturals and `evalU ≤ evalV`; falls back
to syntactic equality for open levels (the `Phase-1` vacuous case
— no free level variables appear in well-formed terms yet).

Used by `Term.subOrConv` to implement §31.4 U-cumul (`Type<u> <:
Type<v>` when `u ≤ v`) at the `Term.check` boundary without making
`convEq` asymmetric.
-/
def leBool (leftLevel rightLevel : Level) : Bool :=
  match leftLevel.eval?, rightLevel.eval? with
  | some leftValue, some rightValue => decide (leftValue ≤ rightValue)
  | none,   none   => decide (leftLevel = rightLevel)
  | _,      _      => false

/-! ### Algebraic cumulativity lemmas

Clients of the kernel use these to discharge `LessEq` obligations
without unfolding `eval?`.  Each follows from the corresponding
`Nat.le` lemma once evaluation is forced.  None of them are
`axiom` declarations — they are derivable from `U-level` and the
structural semantics of `eval?`.
-/

/-- `zero ≤ u` for any closed `u`.  Phase 1 rejects open levels,
    so the closedness hypothesis is always discharged at the
    kernel boundary via `eval?_closed_isSome`. -/
theorem LessEq.zero_le_closed (level : Level) (hClosed : closed level = true) : zero ≤ level := by
  intro value hEvalZero
  simp [eval?] at hEvalZero
  subst hEvalZero
  have hIsSome := eval?_closed_isSome level hClosed
  cases hEval : eval? level with
  | none   => simp [hEval] at hIsSome
  | some levelValue => exact ⟨levelValue, rfl, Nat.zero_le _⟩

/-- `u ≤ succ u` for any level `u`.  Holds regardless of
    closedness — on an open `u` both sides evaluate to `none`
    and `LessEq` is vacuously satisfied. -/
theorem LessEq.le_succ (level : Level) : level ≤ succ level := by
  intro value hEval
  refine ⟨value + 1, ?_, Nat.le_succ _⟩
  simp [eval?, hEval, Option.map]

/-- `succ` is monotone: `u ≤ v` implies `succ u ≤ succ v`. -/
theorem LessEq.succ_mono {leftLevel rightLevel : Level}
    (hLe : leftLevel ≤ rightLevel) : succ leftLevel ≤ succ rightLevel := by
  intro succValue hEvalSucc
  cases hEvalLeft : eval? leftLevel with
  | none    => simp [eval?, hEvalLeft, Option.map] at hEvalSucc
  | some leftValue =>
    obtain ⟨rightValue, hEvalRight, hLeNat⟩ := hLe leftValue hEvalLeft
    refine ⟨rightValue + 1, ?_, ?_⟩
    · simp [eval?, hEvalRight, Option.map]
    · have : succValue = leftValue + 1 := by
        simp [eval?, hEvalLeft, Option.map] at hEvalSucc; exact hEvalSucc.symm
      subst this; exact Nat.succ_le_succ hLeNat

/-- Alias for `LessEq.succ_mono` under the standard mathlib name.
    Same proof obligation; provided for API discoverability and
    pattern-matching in client proofs. -/
theorem LessEq.succ_le_succ {leftLevel rightLevel : Level}
    (hLe : leftLevel ≤ rightLevel) : succ leftLevel ≤ succ rightLevel :=
  LessEq.succ_mono hLe

/-- `u ≤ max u v` when `v` evaluates.  In Phase 1 the checker
    rejects open levels, so the hypothesis is discharged at
    every kernel use site via `eval?_closed_isSome`. -/
theorem LessEq.le_max_left (leftLevel rightLevel : Level)
    (hRightIsSome : (eval? rightLevel).isSome = true) :
    leftLevel ≤ max leftLevel rightLevel := by
  intro leftValue hEvalLeft
  cases hEvalRight : eval? rightLevel with
  | none   => simp [hEvalRight] at hRightIsSome
  | some rightValue =>
    refine ⟨Nat.max leftValue rightValue, ?_, Nat.le_max_left _ _⟩
    simp [eval?, hEvalLeft, hEvalRight]

/-- `v ≤ max u v` when `u` evaluates.  Dual of `le_max_left`. -/
theorem LessEq.le_max_right (leftLevel rightLevel : Level)
    (hLeftIsSome : (eval? leftLevel).isSome = true) :
    rightLevel ≤ max leftLevel rightLevel := by
  intro rightValue hEvalRight
  cases hEvalLeft : eval? leftLevel with
  | none   => simp [hEvalLeft] at hLeftIsSome
  | some leftValue =>
    refine ⟨Nat.max leftValue rightValue, ?_, Nat.le_max_right _ _⟩
    simp [eval?, hEvalLeft, hEvalRight]

/-- `max` is commutative up to evaluation.  Syntactic `max u v`
    and `max v u` are distinct terms but evaluate to the same
    `Nat`. -/
theorem max_eval_comm (leftLevel rightLevel : Level) :
    eval? (max leftLevel rightLevel) = eval? (max rightLevel leftLevel) := by
  cases hEvalLeft : eval? leftLevel <;> cases hEvalRight : eval? rightLevel <;>
    simp [eval?, hEvalLeft, hEvalRight, Nat.max_comm]

/-- `eval?` on `Level.max` is exactly `Nat.max` on the children,
    when both evaluate.  Bridges the `Level.max` / `Nat.max`
    naming: clients reasoning about concrete level values can
    rewrite `eval? (Level.max u v)` to a `Nat.max`. -/
theorem eval?_max_eq (leftLevel rightLevel : Level) {leftValue rightValue : Nat}
    (hEvalLeft : eval? leftLevel = some leftValue)
    (hEvalRight : eval? rightLevel = some rightValue) :
    eval? (max leftLevel rightLevel) = some (Nat.max leftValue rightValue) := by
  simp [eval?, hEvalLeft, hEvalRight]

/-- `max u v ≤ max v u`: both orderings of the join subsume each
    other.  Combined with its symmetric instance this witnesses
    semantic commutativity of `max` as a join-semilattice
    operation.  Syntactic equality does not hold — `LessEq` is a
    preorder, not a partial order, on `Level` terms. -/
theorem LessEq.max_comm (leftLevel rightLevel : Level) :
    max leftLevel rightLevel ≤ max rightLevel leftLevel := by
  intro maxValue hEvalMax
  refine ⟨maxValue, ?_, Nat.le_refl _⟩
  rw [← max_eval_comm]; exact hEvalMax

/-! ### Bool-version theorems for `leBool`

`subOrConv` invokes `leBool` (returns `Bool`) rather than `LessEq`
(returns `Prop`).  These theorems give clients clean named
rewrites for the Bool-level check without going through `LessEq`
first.  Proofs bottom out on `Nat.le_refl` / `Nat.le_trans` via
`decide` unfolding. -/

/-- `leBool u u = true` for any level `u` (including open ones,
    where `eval?` returns `none` and the `= u` syntactic-equality
    fallback fires). -/
theorem leBool_refl (level : Level) : leBool level level = true := by
  unfold leBool
  cases hEval : eval? level with
  | none         => simp
  | some value   => simp

/-- `leBool` is transitive on closed levels.  Open levels compare
    via syntactic equality, which is also transitive, but the
    proof case-splits on `eval?` so we require both closed levels
    for the cleaner version.  A full open-level transitivity would
    require the triple to all be syntactically equal; we don't
    expose that form — Phase 1 rejects open levels at the kernel
    boundary anyway. -/
theorem leBool_trans_closed
    (leftLevel middleLevel rightLevel : Level)
    (hLeftClosed : closed leftLevel = true)
    (hMiddleClosed : closed middleLevel = true)
    (hRightClosed : closed rightLevel = true)
    (hLeftLeMid : leBool leftLevel middleLevel = true)
    (hMidLeRight : leBool middleLevel rightLevel = true) :
    leBool leftLevel rightLevel = true := by
  have hLeftSome := eval?_closed_isSome leftLevel hLeftClosed
  have hMidSome := eval?_closed_isSome middleLevel hMiddleClosed
  have hRightSome := eval?_closed_isSome rightLevel hRightClosed
  cases hEvalL : eval? leftLevel with
  | none    => simp [hEvalL] at hLeftSome
  | some leftValue =>
    cases hEvalM : eval? middleLevel with
    | none    => simp [hEvalM] at hMidSome
    | some middleValue =>
      cases hEvalR : eval? rightLevel with
      | none    => simp [hEvalR] at hRightSome
      | some rightValue =>
        simp [leBool, hEvalL, hEvalM, hEvalR] at hLeftLeMid hMidLeRight ⊢
        exact Nat.le_trans hLeftLeMid hMidLeRight

/-! ### Eval-computation rewrites

These are `rfl`-provable facts that clients cite by name instead
of re-deriving at each use site.  Each unfolds `eval?` to the
matching constructor case.  Proof-by-`rfl` pins them so any
future refactor of `eval?` keeps the boundary behavior explicit. -/

@[simp] theorem eval?_zero : eval? zero = some 0 := rfl

@[simp] theorem eval?_var (varIndex : Nat) : eval? (var varIndex) = none := rfl

theorem eval?_succ (predecessor : Level) :
    eval? (succ predecessor) = (eval? predecessor).map (· + 1) := rfl

/-! ### Closedness rewrites -/

@[simp] theorem closed_zero : closed zero = true := rfl

@[simp] theorem closed_var (varIndex : Nat) : closed (var varIndex) = false := rfl

theorem closed_succ (predecessor : Level) :
    closed (succ predecessor) = closed predecessor := rfl

theorem closed_max (leftLevel rightLevel : Level) :
    closed (max leftLevel rightLevel) = (closed leftLevel && closed rightLevel) := rfl

/-! ### Nat bridge helpers

`ofNat` constructs a closed level from a concrete `Nat`, and
`eval?_ofNat` establishes the round-trip: the level evaluates
back to exactly that `Nat`.  Useful in tests and in downstream
proofs needing a level at a specific universe height. -/

/-- Construct a closed level at height `n`: `ofNat 0 = zero`,
    `ofNat (n+1) = succ (ofNat n)`.  Always closed; always
    evaluates to `some n`. -/
def ofNat : Nat → Level
  | 0       => zero
  | n + 1   => succ (ofNat n)

/-- `ofNat n` always evaluates to exactly `some n`. -/
theorem eval?_ofNat (natHeight : Nat) : eval? (ofNat natHeight) = some natHeight := by
  induction natHeight with
  | zero => rfl
  | succ predHeight inductionHyp =>
    simp [ofNat, eval?_succ, inductionHyp]

/-- `ofNat n` is always closed. -/
theorem closed_ofNat (natHeight : Nat) : closed (ofNat natHeight) = true := by
  induction natHeight with
  | zero => rfl
  | succ predHeight inductionHyp => simp [ofNat, closed_succ, inductionHyp]

/-! ### Max neutral / idempotence on closed levels -/

/-- `max zero u` evaluates identically to `u`, when `u` is
    closed.  Syntactic equality does not hold — the left side
    still has the `max zero` wrapper — but evaluation collapses. -/
theorem max_zero_left_eval (level : Level) (hClosed : closed level = true) :
    eval? (max zero level) = eval? level := by
  have hIsSome := eval?_closed_isSome level hClosed
  cases hEval : eval? level with
  | none => simp [hEval] at hIsSome
  | some levelValue =>
    simp [eval?, hEval]

/-- Dual: `max u zero` evaluates identically to `u` on closed
    `u`.  Zero is the left AND right identity of `max` at the
    value level. -/
theorem max_zero_right_eval (level : Level) (hClosed : closed level = true) :
    eval? (max level zero) = eval? level := by
  have hIsSome := eval?_closed_isSome level hClosed
  cases hEval : eval? level with
  | none => simp [hEval] at hIsSome
  | some levelValue =>
    simp [eval?, hEval]

/-- `max u u` evaluates identically to `u` — idempotence at the
    value level.  Syntactic `max u u ≠ u`; this is strictly an
    evaluation equivalence. -/
theorem max_idem_eval (level : Level) (hClosed : closed level = true) :
    eval? (max level level) = eval? level := by
  have hIsSome := eval?_closed_isSome level hClosed
  cases hEval : eval? level with
  | none => simp [hEval] at hIsSome
  | some levelValue =>
    simp [eval?, hEval]

end Level

end FX.Kernel
