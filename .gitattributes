# Linguist
*.fst linguist-language=FStarX
*.fst linguist-documentation=false
*.fsti linguist-language=FStarX
*.fsti linguist-documentation=false

# Line endings
*.fs* eol=lf
*.ml* eol=lf
Makefile eol=lf
*.sh eol=lf
*.md eol=lf
configure eol=lf
*.mdk eol=lf
.gitignore eol=lf
.ignore eol=lf
/src/tools/* eol=lf

# Frozen OCaml bootstrap — do not diff or merge
/build/ocamlx/stage0/ -diff -merge
/build/ocamlx/stage0/ linguist-generated=true

# Hint files
*.hints -diff -merge
*.hints linguist-generated=true

# Checked modules
*.checked binary
*.checked linguist-generated=true
*.checked.lax binary
*.checked.lax linguist-generated=true

# Batch files
*.bat eol=crlf
