import LeanFX2.HoTT.Path.Groupoid

/-! # HoTT/HIT/Spec — Higher Inductive Type specifications

A HIT is a type defined by:
1. **Point constructors** — usual data constructors
2. **Path constructors** — identity proofs between point constructors

```lean
structure HITSpec where
  points  : List (Σ args, args → Type)        -- point constructors
  paths   : List (Σ args, ParseId)             -- path constructors
  -- coherence proofs etc.
```

## Examples

* `Circle (S¹)` — one point `base`, one path `loop : Id S¹ base base`
* `Suspension (Susp A)` — `north`, `south`, `merid : A → Id (Susp A) north south`
* `Quotient A R` — points from A, paths witnessing R

## Setoid encoding

In standard MLTT without native HITs, this layer starts from a
setoid presentation:
* an underlying carrier with point constructors,
* a relation generated by path constructors,
* explicit preservation proofs for maps out of the presentation.

This file only records the first-order constructor labels.  Concrete
HIT modules must still provide their carriers, relations, eliminators,
and computation rules without importing Lean's quotient axioms.

## Dependencies

* `HoTT/Path/Groupoid.lean`

## Downstream consumers

* `HoTT/HIT/Setoid.lean` — encoding
* `HoTT/HIT/Eliminator.lean` — HIT induction
* `HoTT/HIT/Examples.lean` — concrete HITs
-/

namespace LeanFX2
namespace HoTT
namespace HIT

universe universeLevel

/-- Universe-polymorphic empty label type for HIT presentations with no
path constructors. -/
inductive EmptyPathLabel : Type universeLevel

/-- A first-order presentation of a higher inductive type.

This foundation deliberately records point labels and path labels only.
Concrete HIT files can interpret those labels as constructors and
computation rules without reaching for Lean's quotient machinery. -/
structure HITSpec where
  /-- Labels for point constructors. -/
  pointLabel : Type universeLevel
  /-- Labels for path constructors. -/
  pathLabel : Type universeLevel
  /-- Source point of each path constructor. -/
  pathSource : pathLabel → pointLabel
  /-- Target point of each path constructor. -/
  pathTarget : pathLabel → pointLabel

namespace HITSpec

/-- A path label witnesses a directed path between two point labels. -/
def hasPathBetween (spec : HITSpec.{universeLevel})
    (sourcePoint targetPoint : spec.pointLabel) : Prop :=
  ∃ pathName : spec.pathLabel,
    spec.pathSource pathName = sourcePoint ∧
    spec.pathTarget pathName = targetPoint

/-- A HIT specification with no path constructors. -/
def discrete (pointLabel : Type universeLevel) : HITSpec where
  pointLabel := pointLabel
  pathLabel := EmptyPathLabel
  pathSource := fun pathName => nomatch pathName
  pathTarget := fun pathName => nomatch pathName

/-- Discrete HIT specifications have no path labels. -/
theorem discrete_hasNoPath
    (pointLabel : Type universeLevel)
    (sourcePoint targetPoint : pointLabel) :
    ¬ (HITSpec.discrete pointLabel).hasPathBetween
      sourcePoint targetPoint := by
  intro pathWitness
  cases pathWitness with
  | intro pathName _ => exact nomatch pathName

end HITSpec

end HIT
end HoTT
end LeanFX2
